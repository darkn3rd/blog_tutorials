apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  annotations:
    alb.ingress.kubernetes.io/scheme: internet-facing
    alb.ingress.kubernetes.io/target-type: ip
    kubernetes.io/ingress.class: alb
  name: {{ app_name }}
  namespace: {{ ns }}
spec:
  rules:
  - host: demo.example.com
    http:
      paths:
      - backend:
          service:
            name: {{ app_name }}
            port:
              number: 80
        path: /
        pathType: Prefix
